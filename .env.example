# Copy to .env — never commit .env
APP_ENV=development
DEBUG=true
BUILD_TAG=local

# Min 32 chars — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-min-32-chars!!
ENCRYPTION_KEY=change-me-32-bytes-fernet-key!!!!

ACCESS_TOKEN_EXPIRE_MINUTES=30
ALLOWED_HOSTS=["*"]
