#!/bin/bash
# ═══════════════════════════════════════════════════════════════════════════════
# CipherFlow Pre-Commit Hook
# ═══════════════════════════════════════════════════════════════════════════════
# Runs linting and basic checks before allowing a commit.
# Install: git config core.hooksPath .githooks
# ═══════════════════════════════════════════════════════════════════════════════

set -e

echo "🔍 Running pre-commit checks..."

# Check for secrets in staged files
echo "  Checking for secrets..."
SECRETS_FOUND=0
for pattern in "dop_v1_" "sk_live_" "AKIA" "-----BEGIN.*PRIVATE KEY-----"; do
    if git diff --cached --diff-filter=ACM | grep -qE "$pattern"; then
        echo "  ✗ Potential secret detected matching: $pattern"
        SECRETS_FOUND=1
    fi
done

if [ "$SECRETS_FOUND" -eq 1 ]; then
    echo "  ✗ BLOCKED: Remove secrets before committing"
    exit 1
fi
echo "  ✓ No secrets detected"

# Check for large files
echo "  Checking file sizes..."
LARGE_FILES=$(git diff --cached --diff-filter=ACM --name-only | while read file; do
    if [ -f "$file" ]; then
        size=$(wc -c < "$file")
        if [ "$size" -gt 5242880 ]; then
            echo "$file ($(($size / 1048576))MB)"
        fi
    fi
done)

if [ -n "$LARGE_FILES" ]; then
    echo "  ✗ Large files detected (>5MB):"
    echo "    $LARGE_FILES"
    exit 1
fi
echo "  ✓ No oversized files"

# Run linter if Python files changed
PYTHON_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)
if [ -n "$PYTHON_FILES" ]; then
    echo "  Running ruff linter..."
    if command -v ruff &> /dev/null; then
        ruff check $PYTHON_FILES || {
            echo "  ✗ Lint errors found. Fix with: ruff check --fix"
            exit 1
        }
        echo "  ✓ Lint passed"
    else
        echo "  ⚠ ruff not installed, skipping lint"
    fi
fi

echo "✓ All pre-commit checks passed"
